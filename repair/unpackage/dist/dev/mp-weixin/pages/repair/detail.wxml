<view class="page-shell data-v-1104d353"><view wx:if="{{a}}" class="empty-state data-v-1104d353">工单详情加载中...</view><block wx:elif="{{b}}"><view class="card detail-card data-v-1104d353"><view class="detail-head data-v-1104d353"><view class="data-v-1104d353"><view class="section-title data-v-1104d353">{{c}}</view><view class="muted-text data-v-1104d353">工单号：{{d}}</view></view><view class="tag data-v-1104d353">{{e}}</view></view><view class="detail-row data-v-1104d353"><text class="detail-label data-v-1104d353">区域</text><text class="data-v-1104d353">{{f}}</text></view><view class="detail-row data-v-1104d353"><text class="detail-label data-v-1104d353">位置</text><text class="data-v-1104d353">{{g}}</text></view><view class="detail-row data-v-1104d353"><text class="detail-label data-v-1104d353">上报渠道</text><text class="data-v-1104d353">{{h}}</text></view><view class="detail-row data-v-1104d353"><text class="detail-label data-v-1104d353">上报人</text><text class="data-v-1104d353">{{i}}</text></view><view class="detail-row data-v-1104d353"><text class="detail-label data-v-1104d353">维修人</text><text class="data-v-1104d353">{{j}}</text></view><view class="detail-desc data-v-1104d353">{{k}}</view></view><view wx:if="{{l}}" class="card image-card data-v-1104d353"><view class="section-title data-v-1104d353">现场图片</view><scroll-view scroll-x class="image-scroll data-v-1104d353"><view class="image-row data-v-1104d353"><image wx:for="{{m}}" wx:for-item="item" wx:key="a" class="thumb data-v-1104d353" src="{{item.b}}" mode="aspectFill" bindtap="{{item.c}}"/></view></scroll-view></view><view class="card log-card data-v-1104d353"><view class="section-title data-v-1104d353">处理记录</view><view wx:for="{{n}}" wx:for-item="item" wx:key="e" class="log-item data-v-1104d353"><view class="log-item__title data-v-1104d353">{{item.a}} · {{item.b}}</view><view class="log-item__content data-v-1104d353">{{item.c}}</view><view class="muted-text data-v-1104d353">{{item.d}}</view></view></view><view wx:if="{{o}}" class="card action-card data-v-1104d353"><view class="section-title data-v-1104d353">接单处理</view><button class="primary-btn data-v-1104d353" bindtap="{{p}}">立即接单</button></view><view wx:if="{{q}}" class="card action-card data-v-1104d353"><view class="section-title data-v-1104d353">提交完工结果</view><block wx:if="{{r0}}"><textarea class="field-textarea data-v-1104d353" placeholder="请输入维修说明、处理结果和恢复情况" placeholder-style="color:#7b9bbb" value="{{r}}" bindinput="{{s}}"/></block><button class="ghost-btn mt data-v-1104d353" bindtap="{{t}}">选择完工图片</button><view wx:if="{{v}}" class="muted-text mt data-v-1104d353">已选择 {{w}} 张图片</view><button class="primary-btn mt data-v-1104d353" bindtap="{{x}}">提交完工</button></view></block></view>